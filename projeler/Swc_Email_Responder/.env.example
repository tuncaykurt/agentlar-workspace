# Sweatcoin Email Responder — Gerekli Environment Variables
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin

# ═══════════════════════════════════════════════════════
# 🔐 Google OAuth Token'ları (JSON string olarak)
# Merkezi auth sistemi: shared/google_auth.py
# ═══════════════════════════════════════════════════════

# Sweatcoin hesabı (EMAIL_ADRESI_BURAYA) — Email Responder
# Gmail inbox okuma, draft oluşturma
GOOGLE_SWC_TOKEN_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}

# Outreach hesabı (EMAIL_ADRESI_BURAYA) — Outreach Mailer + Sheets
# Outreach email gönderimi, Sheets okuma/yazma
GOOGLE_OUTREACH_TOKEN_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}

# ═══════════════════════════════════════════════════════
# 🤖 LLM — Groq API (Intent analizi + draft üretimi)
# ═══════════════════════════════════════════════════════
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ═══════════════════════════════════════════════════════
# 📧 Bildirim Sistemi (Hata alarmları)
# ═══════════════════════════════════════════════════════

# SMTP (Email bildirimi — Öncelik 1)
SMTP_USER=your_smtp_email@gmail.com
SMTP_APP_PASSWORD=your_gmail_app_password

# Telegram (Fallback — Email çalışmazsa)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_chat_id

# ═══════════════════════════════════════════════════════
# 🌐 Railway
# ═══════════════════════════════════════════════════════
PORT=8080
