# === Notion API Settings ===
NOTION_TOKEN=your_notion_integration_token

# === OpenAI API Settings ===
OPENAI_API_KEY=your_openai_api_key

# === Google Drive API Settings ===
# Note: Place your Google Drive API credentials.json file in this directory.
# This variable is optional if you just hardcode the path, but good for custom paths.
GOOGLE_CREDENTIALS_FILE=credentials.json

# === App Settings ===
# Optionally define output directories or default fonts
OUTPUT_DIR=outputs
FONTS_DIR=fonts
