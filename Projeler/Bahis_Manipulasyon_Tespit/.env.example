# The Odds API (https://the-odds-api.com) - ücretsiz tier: 500 istek/ay
ODDS_API_KEY=your_api_key_here

# Mock mod: API anahtarı olmadan test için TRUE yap
USE_MOCK_DATA=true

# Alarm eşikleri
ANOMALY_THRESHOLD=0.75      # 0-1 arası, üzeri şüpheli
CRITICAL_THRESHOLD=0.88     # bu eşiğin üzeri kritik alarm

# Polling sıklığı (saniye)
POLL_INTERVAL=5

# Dashboard port
DASHBOARD_PORT=8501
